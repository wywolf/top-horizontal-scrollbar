{
  "manifest_version": 3,
  "name": "横向进度条",
  "version": "1.0",
  "description": "在网页顶部显示横向的滚动阅读进度条，直观掌握长文阅读进度。",
  "author": "Leo",
  "homepage_url": "https://github.com/wywolf/top-horizontal-scrollbar",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["progress.css"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "host_permissions": ["<all_urls>"]
}
